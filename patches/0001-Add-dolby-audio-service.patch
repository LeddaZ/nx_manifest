diff --git a/common/dolby/dolby.mk b/common/dolby/dolby.mk
index 6020d8e..13ec79e 100644
--- a/common/dolby/dolby.mk
+++ b/common/dolby/dolby.mk
@@ -15,4 +15,5 @@
 PRODUCT_PACKAGES += \
                     DolbyAudioService \
                     vendor.dolby.ms12@1.0 \
-                    vendor.nvidia.hardware.ipprotect@1.0-service
+                    vendor.nvidia.hardware.ipprotect@1.0-service \
+                    android.hardware.audio@4.0-service-msd
diff --git a/common/dolby/etc/init/android.hardware.audio@4.0-service-msd.rc b/common/dolby/etc/init/android.hardware.audio@4.0-service-msd.rc
new file mode 100644
index 0000000..a5d3b9b
--- /dev/null
+++ b/common/dolby/etc/init/android.hardware.audio@4.0-service-msd.rc
@@ -0,0 +1,10 @@
+service vendor.audio-hal-4-0-msd /vendor/bin/hw/android.hardware.audio@4.0-service-msd
+    class hal
+    user audioserver
+    # media gid needed for /dev/fm (radio) and for /data/misc/media (tee)
+    group audio camera drmrpc inet media mediadrm net_bt net_bt_admin net_bw_acct
+    ioprio rt 4
+    writepid /dev/cpuset/foreground/tasks /dev/stune/foreground/tasks
+
+on post-fs-data
+    mkdir /data/vendor/dolby 0777 root root
