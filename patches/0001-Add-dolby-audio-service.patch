From e4f11e135d5cf72083a07809cd815ae8e4a4099b Mon Sep 17 00:00:00 2001
From: Billy Laws <blaws05@gmail.com>
Date: Mon, 23 Dec 2019 15:13:37 +0000
Subject: [PATCH] Add dolby audio service

---
 common/audio/manifest.xml                     |   1 +
 common/dolby/Android.mk                       |  24 +++++++++++++-----
 .../hw/android.hardware.audio@4.0-service-msd | Bin 0 -> 1219460 bytes
 common/dolby/dolby.mk                         |   3 ++-
 .../android.hardware.audio@4.0-service-msd.rc |  10 ++++++++
 5 files changed, 31 insertions(+), 7 deletions(-)
 create mode 100755 common/dolby/bin32/hw/android.hardware.audio@4.0-service-msd
 create mode 100644 common/dolby/etc/init/android.hardware.audio@4.0-service-msd.rc

diff --git a/common/audio/manifest.xml b/common/audio/manifest.xml
index c537a1d..b96ffd2 100644
--- a/common/audio/manifest.xml
+++ b/common/audio/manifest.xml
@@ -6,6 +6,7 @@
         <interface>
             <name>IDevicesFactory</name>
             <instance>default</instance>
+            <instance>msd</instance>
         </interface>
     </hal>
     <hal format="hidl">
diff --git a/common/dolby/Android.mk b/common/dolby/Android.mk
index 13dca68..06c0dc0 100644
--- a/common/dolby/Android.mk
+++ b/common/dolby/Android.mk
@@ -37,10 +37,9 @@ LOCAL_MODULE_RELATIVE_PATH := hw
 include $(BUILD_NVIDIA_COMMON_PREBUILT)
 
 include $(CLEAR_VARS)
-LOCAL_MODULE               := vendor.nvidia.hardware.ipprotect@1.0
-LOCAL_SRC_FILES_32         := lib/vendor.nvidia.hardware.ipprotect@1.0.so
-LOCAL_SRC_FILES_64         := lib64/vendor.nvidia.hardware.ipprotect@1.0.so
-LOCAL_MULTILIB             := both
+LOCAL_MODULE               := vendor.dolby.ms12@1.0
+LOCAL_SRC_FILES_32         := lib/vendor.dolby.ms12@1.0.so
+LOCAL_MULTILIB             := 32
 LOCAL_MODULE_SUFFIX        := .so
 LOCAL_MODULE_CLASS         := SHARED_LIBRARIES
 LOCAL_MODULE_TAGS          := optional
@@ -49,9 +48,22 @@ LOCAL_VENDOR_MODULE        := true
 include $(BUILD_NVIDIA_COMMON_PREBUILT)
 
 include $(CLEAR_VARS)
-LOCAL_MODULE               := vendor.dolby.ms12@1.0
-LOCAL_SRC_FILES_32         := lib/vendor.dolby.ms12@1.0.so
+LOCAL_MODULE               := android.hardware.audio@4.0-service-msd
+LOCAL_SRC_FILES_32         := bin32/hw/android.hardware.audio@4.0-service-msd
+LOCAL_INIT_RC              := etc/init/android.hardware.audio@4.0-service-msd.rc
 LOCAL_MULTILIB             := 32
+LOCAL_MODULE_CLASS         := EXECUTABLES
+LOCAL_MODULE_TAGS          := optional
+LOCAL_MODULE_OWNER         := nvidia
+LOCAL_VENDOR_MODULE        := true
+LOCAL_MODULE_RELATIVE_PATH := hw
+include $(BUILD_NVIDIA_COMMON_PREBUILT)
+
+include $(CLEAR_VARS)
+LOCAL_MODULE               := vendor.nvidia.hardware.ipprotect@1.0
+LOCAL_SRC_FILES_32         := lib/vendor.nvidia.hardware.ipprotect@1.0.so
+LOCAL_SRC_FILES_64         := lib64/vendor.nvidia.hardware.ipprotect@1.0.so
+LOCAL_MULTILIB             := both
 LOCAL_MODULE_SUFFIX        := .so
 LOCAL_MODULE_CLASS         := SHARED_LIBRARIES
 LOCAL_MODULE_TAGS          := optional
diff --git a/common/dolby/bin32/hw/android.hardware.audio@4.0-service-msd b/common/dolby/bin32/hw/android.hardware.audio@4.0-service-msd
new file mode 100755
