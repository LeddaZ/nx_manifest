From: Thomas Makin <halorocker89@gmail.com>
Date: Fri, 30 Jul 2021 02:03:57 +0000
Subject: [PATCH] Disable stb rotation hook

Change-Id: I19015497baa467f11ddb18895214c278de2b8586
---
 services/inputflinger/InputReaderHook.cpp | 10 +---------
 1 file changed, 1 insertion(+), 9 deletions(-)

diff --git a/services/inputflinger/InputReaderHook.cpp b/services/inputflinger/InputReaderHook.cpp
index a11429c7c..66e2e56c4 100644
--- a/services/inputflinger/InputReaderHook.cpp
+++ b/services/inputflinger/InputReaderHook.cpp
@@ -286,15 +286,7 @@ int32_t InputReaderHook::getScanCodeLocked(int32_t deviceId, int32_t keyCode) co
 }
 
 void handleStbRotation(int32_t& surfaceWidth, int32_t& surfaceHeight, int32_t& surfaceOrientation) {
-    // Console Mode support for touch scaling/rotation
-    char stb[PROPERTY_VALUE_MAX];
-    property_get("persist.vendor.tegra.stb.mode", stb, "0");
-    if (*stb != '0') {
-        int32_t tmp = surfaceWidth;
-        surfaceWidth = surfaceHeight;
-        surfaceHeight = tmp;
-        surfaceOrientation = (surfaceOrientation + 1) % 4;
-    }
+    // Don't handle stb rotation
 }
 
 }
