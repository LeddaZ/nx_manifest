diff --git a/common/BoardCommon.mk b/common/BoardCommon.mk
index 01fa2ac..d76ec72 100644
--- a/common/BoardCommon.mk
+++ b/common/BoardCommon.mk
@@ -46,10 +46,6 @@ ifeq ($(TARGET_TEGRA_GPS),brcm)
 include $(COMMON_PATH)/gps/BoardGps.mk
 endif
 
-ifeq ($(TARGET_TEGRA_KEYSTORE),nvkeystore)
-include $(COMMON_PATH)/keystore/BoardKeystore.mk
-endif
-
 ifeq ($(TARGET_TEGRA_MEMTRACK),nvmemtrack)
 include $(COMMON_PATH)/memtrack/BoardMemtrack.mk
 endif
diff --git a/common/common-by-flags.mk b/common/common-by-flags.mk
index f2b35a5..ec6e5cc 100644
--- a/common/common-by-flags.mk
+++ b/common/common-by-flags.mk
@@ -50,11 +50,6 @@ ifeq ($(TARGET_TEGRA_CEC),nvhdmi)
 $(call inherit-product, $(LOCAL_PATH)/hdmi/hdmi.mk)
 endif
 
-ifeq ($(TARGET_TEGRA_KEYSTORE),nvkeystore)
-$(call inherit-product, $(LOCAL_PATH)/keystore/keystore.mk)
-$(call inherit-product, $(LOCAL_PATH)/security/security.mk)
-endif
-
 ifeq ($(TARGET_TEGRA_MEMTRACK),nvmemtrack)
 $(call inherit-product, $(LOCAL_PATH)/memtrack/memtrack.mk)
 endif
