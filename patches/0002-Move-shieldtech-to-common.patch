diff --git a/common/BoardCommon.mk b/common/BoardCommon.mk
index 7253469..02c4f18 100644
--- a/common/BoardCommon.mk
+++ b/common/BoardCommon.mk
@@ -14,6 +14,10 @@
 
 COMMON_PATH := vendor/nvidia/common
 
+ifeq ($(NV_ANDROID_FRAMEWORK_ENHANCEMENTS),true)
+include $(COMMON_PATH)/shieldtech/BoardShieldTech.mk
+endif
+
 ifeq ($(TARGET_TEGRA_AUDIO),nvaudio)
 include $(COMMON_PATH)/audio/BoardAudio.mk
 endif
diff --git a/common/common-by-flags.mk b/common/common-by-flags.mk
index ac66b59..7f9bbb4 100644
--- a/common/common-by-flags.mk
+++ b/common/common-by-flags.mk
@@ -14,6 +14,10 @@
 
 LOCAL_PATH := vendor/nvidia/common
 
+ifeq ($(NV_ANDROID_FRAMEWORK_ENHANCEMENTS),true)
+$(call inherit-product, $(LOCAL_PATH)/shieldtech/shieldtech.mk)
+endif
+
 ifeq ($(TARGET_TEGRA_AUDIO),nvaudio)
 $(call inherit-product, $(LOCAL_PATH)/audio/audio.mk)
 endif
